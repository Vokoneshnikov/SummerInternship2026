{% extends 'base.html.twig' %}

{% block title %}Создать короткую ссылку{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <strong>Создать короткую ссылку</strong>
                </div>

                <div class="card-body">
                    {# Вывод flash-сообщений #}
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label }} alert-dismissible fade show">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {{ form_start(form, {'attr': {'id': 'createForm'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.oldLink, 'Оригинальный URL', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.oldLink, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'https://example.com/очень-длинная-ссылка', 'autofocus': true}}) }}
                        {{ form_errors(form.oldLink) }}
                        <div class="form-text">
                            Введите полный URL, который нужно сократить (включая http:// или https://)
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        {{ form_widget(form.isDisposable, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.isDisposable, 'Одноразовая ссылка', {'label_attr': {'class': 'form-check-label'}}) }}
                        <div class="form-text">
                            Одноразовая ссылка будет доступна только для одного перехода
                        </div>
                    </div>

                    <div class="mb-3" id="expiresAtWrapper">
                        {{ form_label(form.expiresAt, 'Дата устаревания (опционально)', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.expiresAt, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.expiresAt) }}
                        <div class="form-text">
                            Если не указать, ссылка будет действительна бессрочно
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Сократить URL
                        </button>
                        <a href="{{ path('home') }}" class="btn btn-outline-secondary">
                            ← К списку моих ссылок
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const disposableCheckbox = document.querySelector('input[name="link[isDisposable]"]');
            const expiresAtWrapper = document.getElementById('expiresAtWrapper');

            if (disposableCheckbox && expiresAtWrapper) {
                // ✅ Показываем/скрываем поле с датой в зависимости от чекбокса
                function toggleExpiresAt() {
                    if (disposableCheckbox.checked) {
                        expiresAtWrapper.style.display = 'block';
                        // Делаем поле обязательным для одноразовой ссылки
                        const expiresAtInput = expiresAtWrapper.querySelector('input');
                        if (expiresAtInput) {
                            expiresAtInput.required = true;
                            expiresAtInput.parentElement.querySelector('.form-text').textContent =
                                '⚠️ Обязательно для одноразовой ссылки';
                        }
                    } else {
                        expiresAtWrapper.style.display = 'block';
                        // Убираем обязательность
                        const expiresAtInput = expiresAtWrapper.querySelector('input');
                        if (expiresAtInput) {
                            expiresAtInput.required = false;
                            expiresAtInput.parentElement.querySelector('.form-text').textContent =
                                'Если не указать, ссылка будет действительна бессрочно';
                        }
                    }
                }

                toggleExpiresAt();
                disposableCheckbox.addEventListener('change', toggleExpiresAt);
            }
        });
    </script>
{% endblock %}
