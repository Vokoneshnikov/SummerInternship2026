{# templates/link/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}All Links - URL Shortener{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-list me-2"></i>
                <strong>All Shortened Links</strong>
                <span class="badge bg-light text-dark ms-2">{{ links|length }}</span>
            </div>
            <a href="{{ path('create_page') }}" class="btn btn-light btn-sm">
                <i class="fas fa-plus me-1"></i> Create New
            </a>
        </div>

        <div class="card-body">
            {% if links is empty %}
                <div class="empty-state">
                    <i class="fas fa-link"></i>
                    <h4>No links yet</h4>
                    <p class="text-muted">Create your first shortened link!</p>
                    <a href="{{ path('create_page') }}" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i> Create Link
                    </a>
                </div>
            {% else %}
                <div class="table-container">
                    <table class="table table-hover">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Original URL</th>
                            <th>Short URL</th>
                            <th>Created</th>
                            <th>Last Used</th>
                            <th class="text-center">Uses</th>
                            <th class="text-center">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for link in links %}
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">{{ link.id }}</span>
                                </td>
                                <td>
                                    <a href="{{ link.oldLink }}" target="_blank" class="text-decoration-none" title="{{ link.oldLink }}">
                                        <span class="url-text">{{ link.oldLink }}</span>
                                    </a>
{#                                    {% if link.oldLink|length > 50 %}#}
{#                                        <button class="btn btn-sm btn-link p-0 ms-1" onclick="alert('{{ link.oldLink|e('js') }}')" title="View full URL">#}
{#                                            <i class="fas fa-eye"></i>#}
{#                                        </button>#}
{#                                    {% endif %}#}
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <a href="{{ path('redirect', {'newLink': link.newLink}) }}" target="_blank" class="text-decoration-none">
                                            <code>{{ link.newLink }}</code>
                                        </a>
                                        <button class="btn btn-sm btn-outline-secondary btn-copy"
                                                onclick="copyToClipboard('{{ app.request.getSchemeAndHttpHost() }}{{ path('redirect', {'newLink': link.newLink}) }}')"
                                                title="Copy short URL">
                                            <i class="fas fa-copy"></i>
                                        </button>
                                    </div>
                                </td>
                                <td>
                                    <small>{{ link.createdAt|date('d.m.Y H:i') }}</small>
                                </td>
                                <td>
                                    <small>{{ link.lastUsedAt|date('d.m.Y H:i') }}</small>
                                </td>
                                <td class="text-center">
                                <span class="badge bg-primary badge-usage">
                                    <i class="fas fa-eye me-1"></i> {{ link.usageCount }}
                                </span>
                                </td>
                                <td class="text-center">
                                    <form action="{{ path('delete', {'id': link.id}) }}" method="POST" style="display: inline;"
                                          onsubmit="return confirm('Are you sure you want to delete this link?')">
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Кнопка "Наверх" -->
    <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="btn btn-primary rounded-circle position-fixed"
            style="bottom: 30px; right: 30px; width: 50px; height: 50px; display: none;"
            id="scrollTopBtn">
        <i class="fas fa-arrow-up"></i>
    </button>

    <script>
        // Функция копирования в буфер обмена
        function copyToClipboard(text) {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(function() {
                    showToast('Copied to clipboard!', 'success');
                }).catch(function() {
                    fallbackCopy(text);
                });
            } else {
                fallbackCopy(text);
            }
        }

        function fallbackCopy(text) {
            var input = document.createElement('input');
            input.value = text;
            document.body.appendChild(input);
            input.select();
            try {
                document.execCommand('copy');
                showToast('Copied to clipboard!', 'success');
            } catch (err) {
                showToast('Failed to copy', 'danger');
            }
            document.body.removeChild(input);
        }

        // Показать уведомление
        function showToast(message, type) {
            var toast = document.createElement('div');
            toast.className = `flash-message alert alert-${type} alert-dismissible fade show`;
            toast.style.position = 'fixed';
            toast.style.top = '20px';
            toast.style.right = '20px';
            toast.style.zIndex = '9999';
            toast.style.maxWidth = '350px';
            toast.innerHTML = `
            <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
            document.body.appendChild(toast);

            setTimeout(function() {
                if (toast.parentNode) {
                    toast.remove();
                }
            }, 3000);
        }

        // Показать/скрыть кнопку "Наверх"
        window.addEventListener('scroll', function() {
            var btn = document.getElementById('scrollTopBtn');
            if (window.scrollY > 300) {
                btn.style.display = 'block';
            } else {
                btn.style.display = 'none';
            }
        });
    </script>
{% endblock %}
