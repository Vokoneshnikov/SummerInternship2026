{# templates/link/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Мои ссылки - URL Shortener{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>Мои сокращенные ссылки</strong>
                <span class="badge bg-light text-dark ms-2">{{ links|length }}</span>
            </div>
            <a href="{{ path('create_page') }}" class="btn btn-primary btn-sm">
                + Создать новую
            </a>
        </div>

        <div class="card-body">
            {% if links is empty %}
                <div class="text-center py-5">
                    <h4>У вас пока нет ссылок</h4>
                    <p class="text-muted">Создайте вашу первую сокращенную ссылку!</p>
                    <a href="{{ path('create_page') }}" class="btn btn-primary">
                        + Создать ссылку
                    </a>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Оригинальный URL</th>
                            <th>Короткая ссылка</th>
                            <th>Создана</th>
                            <th>Последний переход</th>
                            <th class="text-center">Переходов</th>
                            <th class="text-center">Одноразовая</th>
                            <th class="text-center">Устаревает</th>
                            <th class="text-center">Действия</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for link in links %}
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">{{ link.id }}</span>
                                </td>
                                <td>
                                    <a href="{{ link.oldLink }}" target="_blank" class="text-decoration-none" title="{{ link.oldLink }}">
                                        {{ link.oldLink|length > 50 ? link.oldLink|slice(0, 50) ~ '...' : link.oldLink }}
                                    </a>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <a href="{{ path('redirect', {'newLink': link.newLink}) }}" target="_blank" class="text-decoration-none">
                                            <code>{{ link.newLink }}</code>
                                        </a>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                onclick="copyToClipboard('{{ app.request.getSchemeAndHttpHost() }}{{ path('redirect', {'newLink': link.newLink}) }}')"
                                                title="Копировать">
                                            Копировать
                                        </button>
                                    </div>
                                </td>
                                <td>
                                    <small>{{ link.createdAt|date('d.m.Y H:i') }}</small>
                                </td>
                                <td>
                                    <small>{{ link.lastUsedAt|date('d.m.Y H:i') }}</small>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary">{{ link.usageCount }}</span>
                                </td>
                                <td class="text-center">
                                    {% if link.isDisposable %}
                                        <span class="badge bg-warning">Да</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Нет</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if link.expiresAt %}
                                        <span class="badge bg-danger">{{ link.expiresAt|date('d.m.Y H:i') }}</span>
                                    {% else %}
                                        <span class="badge bg-success">∞</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <form action="{{ path('delete', {'id': link.id}) }}" method="POST" style="display: inline;"
                                          onsubmit="return confirm('Вы уверены, что хотите удалить эту ссылку?')">
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            Удалить
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <script>
        function copyToClipboard(text) {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(function() {
                    showToast('Ссылка скопирована!');
                }).catch(function() {
                    fallbackCopy(text);
                });
            } else {
                fallbackCopy(text);
            }
        }

        function fallbackCopy(text) {
            var input = document.createElement('input');
            input.value = text;
            document.body.appendChild(input);
            input.select();
            try {
                document.execCommand('copy');
                showToast('Ссылка скопирована!');
            } catch (err) {
                alert('Не удалось скопировать ссылку');
            }
            document.body.removeChild(input);
        }

        function showToast(message) {
            var toast = document.createElement('div');
            toast.className = 'alert alert-success alert-dismissible fade show';
            toast.style.position = 'fixed';
            toast.style.top = '20px';
            toast.style.right = '20px';
            toast.style.zIndex = '9999';
            toast.style.maxWidth = '350px';
            toast.innerHTML = message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
            document.body.appendChild(toast);

            setTimeout(function() {
                if (toast.parentNode) {
                    toast.remove();
                }
            }, 3000);
        }
    </script>
{% endblock %}
